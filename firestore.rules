rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any logged-in user can read profiles (for community features)
      allow read: if request.auth != null;
      // Only the account owner can write their own profile
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Posts (community feed + prayer wall) ───────────────────────────────
    match /posts/{postId} {
      // Anyone (including guests) can read posts
      allow read: if true;

      // Only logged-in users can create posts — must own the post
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000;

      // Any logged-in user can update likes/prayers counts
      allow update: if request.auth != null;

      // Only the post owner can delete their post
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
